# ============================================
# XAVIER BACKEND — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control.
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Groq API (LLM Inference)
GROQ_API_KEY=your-groq-api-key-here

# Serper.dev (Web Search)
SERPER_API_KEY=your-serper-api-key-here

# NewsAPI.org (News Aggregation)
NEWSAPI_KEY=your-newsapi-key-here

# Redis
REDIS_URL=redis://redis:6379/0

# SearXNG
SEARXNG_URL=http://searxng:8080

# FreshRSS
FRESHRSS_URL=http://freshrss:80
FRESHRSS_API_PASSWORD=changeme

# File Storage (Cloudflare R2)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=xavier-uploads

# App Configuration
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=50
FILE_RETENTION_HOURS=24

# Rate Limits (per user per day)
RATE_LIMIT_FACT_CHECK=10
RATE_LIMIT_IMAGE_CHECK=20
RATE_LIMIT_TEXT_CHECK=30
